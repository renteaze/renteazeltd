<style>
	.bg-dark {
		position: fixed;
		top: 0;
		right: 0;
		bottom: 0;
		left: 0;
		width: 100vw;
		height: 100vh;
		background: #000000;
		display: flex;
		justify-content: center;
		align-items: center;
		z-index: 30;
	}

	.brand-logo {
		width: 80px;
		height: 80px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
	}

	.circle::before,
	.circle::after {
		content: '';
		animation: scale 1s ease-in-out infinite alternate-reverse;
		transition: transform 1s ease-in-out;
		height: 91.74px;
		width: 91.74px;
		position: absolute;
		border-radius: 50%;
		display: flex;
		justify-content: center;
		align-items: center;
		border: 1px solid #47bfa3;
	}
	.circle::before {
		animation-delay: 700ms !important;
		height: 70px;
		width: 70px;
	}

	.iconSvg {
		animation: scaleOut 2s cubic-bezier(0.5, 0.39, 0.23, 1.06) infinite
			100ms alternate-reverse;
		transition: transform 1s cubic-bezier(0.5, 0.39, 0.23, 1.06);
	}

	@keyframes scale {
		0% {
			transform: scale(0.7);
			opacity: 0.5;
		}
		100% {
			transform: scale(1);
		}
	}
</style>
